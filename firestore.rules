rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Holds the hash of your passphrase. Nobody — not even you — can read
    // or write this through the app; it's only ever checked internally by
    // the rule below via get(). You create/edit this one document by hand
    // in the Firebase console.
    match /secret/key {
      allow read, write: if false;
    }

    // The calendar itself: anyone can read it (so others can view the
    // calendar), but a write only succeeds if it carries the correct
    // passphrase hash.
    match /calendar/{docId} {
      allow read: if true;
      allow write: if request.resource.data.keys().hasOnly(['entries', '_auth'])
                   && request.resource.data._auth ==
                      get(/databases/$(database)/documents/secret/key).data.hash;
    }
  }
}

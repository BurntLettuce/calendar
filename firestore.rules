rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // The calendar itself: anyone can read it so others can view the calendar
    match /calendar/{docId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == "g4gaoeCs1FXrkRiUv6jJjrzxUaU2"
                   && request.resource.data.keys().hasOnly(['entries']);
    }
  }
}
